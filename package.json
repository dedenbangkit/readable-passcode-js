{
  "name": "readable-passcode",
  "version": "1.0.0",
  "description": "Generate human-friendly, memorable passcodes like 'mango-river-27' instead of ugly codes like '839201'",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src test --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "passcode",
    "password",
    "otp",
    "code",
    "readable",
    "human-friendly",
    "memorable",
    "generator",
    "invite-code",
    "verification",
    "speakable"
  ],
  "author": "dedenbangkit",
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dedenbangkit/readable-passcode-js.git"
  },
  "bugs": {
    "url": "https://github.com/dedenbangkit/readable-passcode-js/issues"
  },
  "homepage": "https://github.com/dedenbangkit/readable-passcode-js#readme",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "eslint": "^8.56.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=18"
  }
}
